# ============================================================
# Digital Health Africa AI Agent — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ─────────────────────────────────────────
# AI PROVIDER (choose one or both)
# ─────────────────────────────────────────
AI_PROVIDER=claude                          # "claude" (recommended) or "openai"

# Anthropic Claude — get key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI — get key at: https://platform.openai.com (optional)
OPENAI_API_KEY=sk-your-openai-key-here

# Model tiers: "fast" | "balanced" | "powerful"
SCRAPER_MODEL=balanced
VERIFIER_MODEL=powerful
ENRICHER_MODEL=balanced
IMPACT_MODEL=balanced
WRITER_MODEL=balanced

# ─────────────────────────────────────────
# SEARCH / SCRAPING APIs
# ─────────────────────────────────────────
# Tavily — primary web+social search (REQUIRED for scraping)
# Get free key at: https://app.tavily.com
TAVILY_API_KEY=tvly-your-key-here

# Twitter/X API — for direct Twitter search (optional, enhances Twitter results)
# Get at: https://developer.twitter.com → Create App → Bearer Token
TWITTER_BEARER_TOKEN=

# Serper — Google search fallback (optional)
# Get at: https://serper.dev
SERPER_API_KEY=

# GitHub — for open-source repository monitoring (optional, raises rate limit 60→5000 req/hr)
# Get at: https://github.com/settings/tokens → Generate new token (no special scopes needed)
GITHUB_TOKEN=ghp_your-token-here

# Unpaywall — for open-access academic paper lookups (optional, enter your email)
UNPAYWALL_EMAIL=your-email@example.com

# ─────────────────────────────────────────
# SCHEDULING
# ─────────────────────────────────────────
SCHEDULE_HOUR=7                             # 24h format (7 = 7 AM)
SCHEDULE_MINUTE=0
SCHEDULE_DAY_OF_WEEK=mon                    # mon | tue | wed | thu | fri | sat | sun
TIMEZONE=Africa/Nairobi                     # Change to your timezone
# Other timezones: Africa/Lagos, Africa/Cairo, Africa/Johannesburg, Asia/Kolkata, America/New_York
SEARCH_LOOKBACK_DAYS=7                      # How many days back to search for articles

# ─────────────────────────────────────────
# EMAIL (optional — sends PDF to recipients)
# ─────────────────────────────────────────
EMAIL_ENABLED=false                         # Set to "true" to enable
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-app-password             # Gmail: use App Password (not main password)
EMAIL_FROM=your-gmail@gmail.com
EMAIL_TO=recipient1@example.com,recipient2@example.com

# Send immediate email for URGENT-classified articles (bypasses weekly digest)
URGENT_EMAIL_PUSH=true

# ─────────────────────────────────────────
# PIPELINE SETTINGS
# ─────────────────────────────────────────
MAX_ARTICLES_PER_RUN=100                    # Max articles to process per run
MIN_VERIFICATION_SCORE=0.65                 # Articles below this score are filtered out (0.0-1.0)
MAX_FOLLOW_UP_LINKS=5                       # Follow-up reading links per article

# ─────────────────────────────────────────
# OUTPUT & DATABASE
# ─────────────────────────────────────────
PDF_OUTPUT_DIR=./reports                    # Where PDFs are saved
DATABASE_URL=sqlite:///./digital_health_agent.db
